{
  "name": "@_mustachio/ai-review-agent",
  "version": "0.1.0",
  "description": "AI-powered PR code review agent — CLI and CI integration for GitHub and Bitbucket",
  "type": "module",
  "main": "dist/core/engine.js",
  "bin": {
    "ai-review-agent": "dist/cli.js"
  },
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --target node --splitting",
    "dev": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "code-review",
    "pull-request",
    "bitbucket",
    "cli",
    "opencode"
  ],
  "author": "_mustachio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/the-human-mustachio/ai-review-agent"
  },
  "files": [
    "dist/",
    "prompts/",
    ".opencode/"
  ],
  "dependencies": {
    "@octokit/rest": "^21.1.1",
    "@opencode-ai/sdk": "^1.3.3",
    "opencode-ai": "^1.3.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.0",
    "semantic-release": "^25.0.3"
  },
  "release": {
    "branches": ["main"],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github"
    ]
  }
}
